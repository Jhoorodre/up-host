# Optional environment settings for local development
# Copy to .env and fill with your values.

# Paths
MANGA_ROOT_FOLDER=
MANGA_OUTPUT_FOLDER=

# Logging
LOG_LEVEL=INFO

# Default host (Catbox, Imgur, ImgBB, Lensdump, Pixeldrain, Gofile, ImageChest, Imgbox, ImgHippo, ImgPile)
DEFAULT_HOST=Catbox

# GitHub (optional)
GITHUB_TOKEN=
GITHUB_REPO=
GITHUB_BRANCH=main
GITHUB_FOLDER=metadata

# Optional host credentials
IMGUR_CLIENT_ID=
IMGBB_API_KEY=
LENSDUMP_API_KEY=
PIXELDRAIN_API_KEY=
IMGHIPPO_API_KEY=
IMGPILE_API_KEY=
IMGBOX_SESSION_COOKIE=
CATBOX_USERHASH=
